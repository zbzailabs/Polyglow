{
  "name": "polyglow-next",
  "type": "module",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24 <27"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "workerd"
    ]
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "preview:worker": "pnpm run build && wrangler dev",
    "astro": "astro",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,astro,md,mdx,json}\"",
    "typecheck": "astro check",
    "check": "pnpm test && pnpm typecheck && pnpm build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --grep-invert \"visual regression baseline\"",
    "deploy:check": "node scripts/deploy-check.mjs",
    "deploy": "pnpm run deploy:check && pnpm run build && wrangler deploy",
    "theme:check": "node scripts/theme-check.mjs",
    "theme:init": "node scripts/theme-init.mjs",
    "theme:reset": "node scripts/theme-reset.mjs",
    "assets:upload": "node scripts/assets-upload.mjs",
    "assets:check": "node scripts/assets-check.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@iconify-json/lucide": "^1.2.106",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.3.1",
    "astro-expressive-code": "^0.42.0",
    "astro-icon": "^1.1.5",
    "astro-pagefind": "^1.8.6",
    "astro-seo": "^1.1.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  }
}
