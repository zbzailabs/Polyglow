---
import type { PostEntry } from "@/utils/posts"
import { postUrl } from "@/utils/posts"
import { getCategory } from "@/config/taxonomy"
import OptimizedPicture from "@/components/features/OptimizedPicture.astro"

interface Props {
  post: PostEntry
  priority?: boolean
  variant?: "lead" | "wide" | "portrait"
  class?: string
}

const {
  post,
  priority = false,
  variant = "portrait",
  class: className = "",
} = Astro.props
const category = getCategory(post.data.category)
const categoryLabel =
  category?.labelByLocale[post.data.locale] ?? post.data.category
const dateLabel = new Intl.DateTimeFormat(post.data.locale, {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(post.data.pubDate)
const cardShape = {
  lead: "h-[27rem] rounded-[1.75rem] sm:h-auto sm:aspect-[16/9] sm:min-h-[27rem]",
  wide: "h-[20rem] rounded-3xl sm:h-auto sm:aspect-[16/10] sm:min-h-[20rem]",
  portrait: "h-[25rem] rounded-3xl sm:h-auto sm:aspect-[3/4] sm:min-h-[24rem]",
}[variant]
const contentShape =
  variant === "lead"
    ? "left-1.5 bottom-1.5 max-w-[34rem] rounded-[1.35rem] p-5 sm:p-8"
    : "inset-x-1.5 bottom-1.5 rounded-2xl p-4 sm:p-5"
const titleClass =
  variant === "lead"
    ? "line-clamp-2 text-3xl font-semibold leading-tight tracking-tight sm:text-4xl"
    : "line-clamp-3 text-xl font-semibold leading-tight tracking-tight"
const TitleTag = variant === "lead" ? "h1" : "h2"
---

<article
  class={`post-card group relative overflow-hidden ${cardShape} ${className}`}
  data-glass-card
>
  <a
    href={postUrl(post)}
    class="absolute inset-0 z-20"
    aria-label={post.data.title}></a>
  <OptimizedPicture
    src={post.data.heroImage}
    alt={post.data.heroImageAlt}
    width={post.data.heroImageWidth}
    height={post.data.heroImageHeight}
    loading={priority ? "eager" : "lazy"}
    class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-700 ease-out"
  />
  <div
    class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent"
  >
  </div>
  <div
    class={`post-card__content absolute z-10 text-white ${contentShape}`}
    data-glass-target
  >
    <div
      class="mb-3 flex w-full items-center justify-between gap-3 text-xs text-white/75"
    >
      <span class="card-meta-pill" data-category={post.data.category}
        >{categoryLabel}</span
      >
      <time class="shrink-0 text-end" datetime={post.data.pubDate.toISOString()}
        >{dateLabel}</time
      >
    </div>
    <TitleTag class={titleClass}>{post.data.title}</TitleTag>
    {
      variant === "lead" && (
        <p class="mt-3 line-clamp-3 text-base leading-7 text-white/80">
          {post.data.description}
        </p>
      )
    }
  </div>
</article>
