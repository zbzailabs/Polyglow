---
import type { PostEntry } from "@/utils/posts"
import { postCategorySlug, postUrl } from "@/utils/posts"
import { getCategory } from "@/config/taxonomy"
import OptimizedPicture from "@/components/features/OptimizedPicture.astro"

interface Props {
  post: PostEntry
  priority?: boolean
  variant?: "lead" | "wide" | "portrait"
  headingLevel?: 2 | 3
  class?: string
}

const {
  post,
  priority = false,
  variant = "portrait",
  headingLevel = 2,
  class: className = "",
} = Astro.props
const categorySlug = postCategorySlug(post)
const category = getCategory(categorySlug)
const categoryLabel =
  category?.labelByLocale[post.data.locale] ?? categorySlug
const dateLabel = new Intl.DateTimeFormat(post.data.locale, {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(post.data.pubDate)
const portraitCardShape =
  "aspect-[3/4] rounded-none sm:min-h-[24rem]"
const cardShape = {
  lead: "aspect-[3/4] rounded-none sm:aspect-[16/9] sm:min-h-[27rem]",
  wide: `${portraitCardShape} xl:aspect-[16/10] xl:min-h-[20rem]`,
  portrait: portraitCardShape,
}[variant]
const contentShape =
  variant === "lead"
    ? "inset-x-0 bottom-0 p-5 sm:p-8"
    : "inset-x-0 bottom-0 p-4 sm:p-5"
const titleClass =
  variant === "lead"
    ? "line-clamp-2 text-[clamp(2rem,5vw,3rem)] leading-tight font-semibold tracking-tight"
    : "line-clamp-3 text-[clamp(1.25rem,2.5vw,1.5rem)] leading-tight font-semibold tracking-tight"
const imageWidths = {
  lead: [640, 768, 960, 1200],
  wide: [420, 640, 720, 960, 1200],
  portrait: [320, 420, 640, 768],
}[variant]
const imageSizes = {
  lead: "(max-width: 639px) calc(100vw - 2rem), (max-width: 1279px) calc(100vw - 3rem), 1152px",
  wide: "(max-width: 767px) calc(100vw - 2rem), (max-width: 1279px) calc((100vw - 4.5rem) / 2), 576px",
  portrait: "(max-width: 639px) calc(100vw - 2rem), (max-width: 1023px) 50vw, 384px",
}[variant]
const TitleTag = headingLevel === 3 ? "h3" : "h2"
---

<article
  class={`post-card group relative w-full min-w-0 max-w-full overflow-hidden transition-transform duration-300 ease-apple-spring active:scale-[0.95] ${cardShape} ${className}`}
>
  <a
    href={postUrl(post)}
    class="absolute inset-0 z-20"
    aria-label={post.data.title}></a>
  <OptimizedPicture
    src={post.data.heroImage}
    alt={post.data.heroImageAlt}
    width={post.data.heroImageWidth}
    height={post.data.heroImageHeight}
    widths={imageWidths}
    sizes={imageSizes}
    priority={priority}
    class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-700 ease-out"
  />
  <div
    class="absolute inset-0 bg-black/35"
  >
  </div>
  <div
    class={`post-card__content absolute z-10 text-center text-white ${contentShape}`}
  >
    <div
      class="mb-3 flex w-full items-center justify-center gap-3 text-xs text-white/75"
    >
      <span class="card-meta-pill" data-category={categorySlug}
        >{categoryLabel}</span
      >
      <time class="shrink-0 text-end" datetime={post.data.pubDate.toISOString()}
        >{dateLabel}</time
      >
    </div>
    <TitleTag class={titleClass}>{post.data.title}</TitleTag>
    {
      variant === "lead" && (
        <p class="mt-3 line-clamp-3 text-base leading-7 text-white/80">
          {post.data.description}
        </p>
      )
    }
  </div>
</article>
