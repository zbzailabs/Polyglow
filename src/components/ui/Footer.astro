---
import { Image } from "astro:assets"
import type { Locale } from "@/config/locales"
import Icon from "@/components/icons/Icon.astro"
import { SITE_CONFIG } from "@/config/site"
import { getPrimaryCategories, getTagsForCategory } from "@/config/taxonomy"
import { localePath } from "@/utils/routes"
import { t } from "@/utils/translations"
import logo from "@/assets/logo.svg"

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const year = new Date().getFullYear()
const primaryCategories = getPrimaryCategories()
---

<footer class="w-full" data-pagefind-ignore>
  <div
    class="mx-auto grid max-w-6xl gap-10 px-4 py-12 text-sm text-muted-foreground sm:px-6 md:grid-cols-[1.8fr_1fr_1fr_1fr_1fr]"
  >
    <div class="flex flex-col gap-6">
      <a
        href={localePath(lang, "/")}
        class="flex w-fit items-center gap-2.5 text-lg font-semibold text-foreground"
      >
        <Image
          src={logo}
          alt=""
          width={24}
          height={24}
          class="size-6"
          loading="lazy"
        />
        <span>{SITE_CONFIG.name}</span>
      </a>
      <div class="flex items-center gap-4">
        <a
          class="inline-flex size-8 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
          href={SITE_CONFIG.repository}
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
        >
          <Icon name="github" class="size-4" dataIcon="inline-start" />
        </a>
        <a
          class="inline-flex size-8 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
          href={SITE_CONFIG.social.x}
          target="_blank"
          rel="noreferrer"
          aria-label="X"
        >
          <Icon name="x" class="size-4" dataIcon="inline-start" />
        </a>
        <a
          class="inline-flex size-8 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
          href={`/${lang}/rss.xml`}
          aria-label="RSS"
        >
          <Icon name="rss" class="size-4" dataIcon="inline-start" />
        </a>
      </div>
      <p class="text-xs">© {year} {SITE_CONFIG.name}</p>
    </div>
    {
      primaryCategories.map((category) => (
        <nav
          class="grid content-start gap-3"
          aria-label={category.labelByLocale[lang]}
        >
          <a
            class="w-fit font-semibold text-foreground transition-colors hover:text-foreground/75"
            href={localePath(lang, `/category/${category.slug}/`)}
          >
            {category.labelByLocale[lang]}
          </a>
          {getTagsForCategory(category.slug).map((tag) => (
            <a
              class="w-fit hover:text-foreground"
              href={localePath(lang, `/tags/${tag.slug}/`)}
            >
              {tag.labelByLocale[lang]}
            </a>
          ))}
        </nav>
      ))
    }
    <nav class="grid content-start gap-3" aria-label={t(lang, "footer.more")}>
      <p class="font-semibold text-foreground">{t(lang, "footer.more")}</p>
      <a
        class="w-fit hover:text-foreground"
        href={localePath(lang, "/category/")}>{t(lang, "footer.categories")}</a
      >
      <a class="w-fit hover:text-foreground" href={localePath(lang, "/tags/")}
        >{t(lang, "footer.tags")}</a
      >
      <a class="w-fit hover:text-foreground" href={localePath(lang, "/author/")}
        >{t(lang, "footer.author")}</a
      >
    </nav>
  </div>
</footer>
