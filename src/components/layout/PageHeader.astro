---
interface Props {
  title: string
  subtitle?: string
  description?: string
  eyebrow?: string
  stat?: string
  align?: "center" | "start"
  class?: string
}

const {
  title,
  subtitle,
  description,
  eyebrow,
  stat,
  align = "center",
  class: className = "",
} = Astro.props
const alignment = align === "center" ? "mx-auto text-center" : ""
---

<section class={`mb-8 max-w-3xl ${alignment} ${className}`} data-page-header>
  {
    eyebrow && (
      <p
        class="mb-3 text-[12px] font-normal tracking-widest-caps text-zinc-500 uppercase"
        data-page-eyebrow
      >
        {eyebrow}
      </p>
    )
  }
  <h1 class="text-[clamp(2rem,5vw,3rem)] leading-tight font-semibold tracking-tightest text-foreground">{title}</h1>
  {
    subtitle && (
      <h2 class="mx-auto mt-3 max-w-3xl text-[clamp(1.0625rem,2.4vw,1.25rem)] leading-[1.47] font-normal tracking-[-0.012em] text-foreground/75">
        {subtitle}
      </h2>
    )
  }
  {
    description && (
      <p class="mx-auto mt-3 max-w-2xl text-sm leading-7 text-muted-foreground sm:text-base">
        {description}
      </p>
    )
  }
  {
    stat && (
      <p
        class="mt-5 inline-flex min-h-8 items-center text-[12px] font-normal tracking-widest-caps text-zinc-500 uppercase"
        data-page-stat
      >
        {stat}
      </p>
    )
  }
</section>
