---
import "@/styles/global.css"
import { SEO } from "astro-seo"
import { optimizeRemoteImageUrl } from "@/config/assets"
import { LOCALES, getLocaleMeta, type Locale } from "@/config/locales"
import { SITE_CONFIG } from "@/config/site"
import { buildAlternates, canonicalUrl } from "@/utils/routes"
import { t } from "@/utils/translations"
import { webPageJsonLd, webSiteJsonLd } from "@/utils/structured-data"
import Header from "@/components/ui/Header.astro"
import Footer from "@/components/ui/Footer.astro"
import DynamicGlass from "@/components/features/DynamicGlass.astro"
import GTMHead from "@/components/widgets/GTMHead.astro"
import GTMBody from "@/components/widgets/GTMBody.astro"
import Adsense from "@/components/widgets/Adsense.astro"
import X402 from "@/components/widgets/X402.astro"

interface Props {
  lang: Locale
  path?: string
  title?: string
  description?: string
  image?: string
  ogType?: "website" | "article"
  noindex?: boolean
  jsonLd?: unknown
  dynamicGlass?: boolean
}

const {
  lang,
  path = "/",
  title = SITE_CONFIG.name,
  description,
  image = SITE_CONFIG.defaultOgImage,
  ogType = "website",
  noindex = false,
  jsonLd,
  dynamicGlass = false,
} = Astro.props
const localeMeta = getLocaleMeta(lang)
const alternates = buildAlternates(path)
const pageDescription = description ?? t(lang, "site.description")
const pageTitle =
  title === SITE_CONFIG.name || title.includes(SITE_CONFIG.name)
    ? title
    : `${title} | ${SITE_CONFIG.name}`
const canonical = canonicalUrl(lang, path)
const isUnsplashImage = image.startsWith("https://images.unsplash.com/")
const absoluteImage = image.startsWith("http")
  ? image
  : `${SITE_CONFIG.url}${image}`
const preloadImage = isUnsplashImage
  ? optimizeRemoteImageUrl(image, 720)
  : undefined
const baseJsonLd = [
  webSiteJsonLd(lang),
  webPageJsonLd({
    lang,
    path,
    title: pageTitle,
    description: pageDescription,
    image,
  }),
]
const jsonLdItems = jsonLd
  ? baseJsonLd.concat(Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : baseJsonLd
const languageAlternates = noindex
  ? undefined
  : Object.entries(alternates).map(([hrefLang, href]) => ({
      hrefLang,
      href,
    }))
const alternateOgLocales = LOCALES.filter((locale) => locale !== lang).map(
  (locale) => getLocaleMeta(locale).ogLocale
)
---

<html lang={localeMeta.hreflang} dir={localeMeta.dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="content-language" content={localeMeta.hreflang} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {
      isUnsplashImage && (
        <>
          <link
            rel="preconnect"
            href="https://images.unsplash.com"
            crossorigin
          />
          <link rel="dns-prefetch" href="https://images.unsplash.com" />
          <link
            rel="preload"
            as="image"
            href={preloadImage}
            fetchpriority="high"
            crossorigin="anonymous"
          />
        </>
      )
    }
    <SEO
      title={pageTitle}
      description={pageDescription}
      canonical={canonical}
      noindex={noindex}
      languageAlternates={languageAlternates}
      openGraph={{
        basic: {
          title: pageTitle,
          type: ogType,
          image: absoluteImage,
          url: canonical,
        },
        optional: {
          description: pageDescription,
          locale: localeMeta.ogLocale,
          localeAlternate: alternateOgLocales,
          siteName: SITE_CONFIG.name,
        },
        image: {
          alt: pageTitle,
        },
      }}
      twitter={{
        card: "summary_large_image",
        site: SITE_CONFIG.social.xHandle,
        creator: SITE_CONFIG.social.xHandle,
        title: pageTitle,
        description: pageDescription,
        image: absoluteImage,
        imageAlt: pageTitle,
      }}
    />
    <script is:inline>
      ;(() => {
        const theme = localStorage.getItem("theme") || "system"
        const resolved =
          theme === "system"
            ? matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light"
            : theme
        document.documentElement.classList.toggle("dark", resolved === "dark")
      })()
    </script>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLdItems)}
    />
    <GTMHead />
    <Adsense />
    <X402 />
  </head>
  <body>
    <GTMBody />
    <Header lang={lang} path={path} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
    {dynamicGlass && <DynamicGlass />}
  </body>
</html>
