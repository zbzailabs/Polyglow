---
import { Image } from "astro:assets"
import Layout from "@/layouts/main.astro"
import Icon from "@/components/icons/Icon.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import PageSection from "@/components/layout/PageSection.astro"
import { LOCALES, type Locale } from "@/config/locales"
import { getAuthor } from "@/utils/content"
import { getPostsForLocale, postUrl } from "@/utils/posts"
import { t } from "@/utils/translations"
import authorImage from "@/assets/author.avif"

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang }, props: { lang } }))
}

const { lang } = Astro.props as { lang: Locale }
const author = await getAuthor(lang)
const title = t(lang, "pages.author.title")
const writingActivityLabel = t(lang, "pages.author.writingActivity")
const publishedText = t(lang, "post.publishedAt")
const authorSlug = author?.data.slug ?? "default"
const authorPosts = (await getPostsForLocale(lang)).filter((post) =>
  post.data.authors.includes(authorSlug)
)
const publicationYears = [
  ...new Set(authorPosts.map((post) => post.data.pubDate.getFullYear())),
].sort((a, b) => b - a)
const activeYear = publicationYears[0] ?? new Date().getFullYear()
const monthFormatter = new Intl.DateTimeFormat(lang, { month: "short" })
const dateFormatter = new Intl.DateTimeFormat(lang, {
  month: "short",
  day: "numeric",
  year: "numeric",
})
const activityMonths = Array.from({ length: 12 }, (_, month) =>
  monthFormatter.format(new Date(2026, month, 1))
)
const dateKey = (date: Date) =>
  `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}-${String(
    date.getDate()
  ).padStart(2, "0")}`
const publishedByDate = authorPosts.reduce((map, post) => {
  const key = dateKey(post.data.pubDate)
  map.set(key, (map.get(key) ?? 0) + 1)
  return map
}, new Map<string, number>())
const yearPostCount = authorPosts.filter(
  (post) => post.data.pubDate.getFullYear() === activeYear
).length
const calendarStart = new Date(activeYear, 0, 1)
calendarStart.setDate(calendarStart.getDate() - calendarStart.getDay())
const calendarEnd = new Date(activeYear, 11, 31)
calendarEnd.setDate(calendarEnd.getDate() + (6 - calendarEnd.getDay()))
const weekCount =
  Math.floor(
    (calendarEnd.getTime() - calendarStart.getTime()) /
      (7 * 24 * 60 * 60 * 1000)
  ) + 1
const activityWeeks = Array.from({ length: weekCount }, (_, week) =>
  Array.from({ length: 7 }, (_, day) => {
    const date = new Date(calendarStart)
    date.setDate(calendarStart.getDate() + week * 7 + day)
    const count =
      date.getFullYear() === activeYear
        ? (publishedByDate.get(dateKey(date)) ?? 0)
        : 0
    return {
      key: dateKey(date),
      count,
      label: `${publishedText}: ${dateFormatter.format(date)}`,
    }
  })
)
const activityLevelClass = (count: number) => {
  if (count >= 4) return "bg-[#216e39] dark:bg-[#39d353]"
  if (count === 3) return "bg-[#30a14e] dark:bg-[#26a641]"
  if (count === 2) return "bg-[#40c463] dark:bg-[#006d32]"
  if (count === 1) return "bg-[#9be9a8] dark:bg-[#0e4429]"
  return "bg-[#ebedf0] ring-1 ring-[#d0d7de] dark:bg-[#161b22] dark:ring-[#30363d]"
}
const recentPublishedPosts = authorPosts.slice(0, 6)
---

<Layout
  lang={lang}
  path="/author/"
  title={title}
  description={author?.data.bio}
>
  <PageSection class="py-8" pagefindIgnore={false}>
    <PageHeader title={title} subtitle={author?.data.bio} />
    <article
      class="author-card mx-auto mt-16 grid max-w-5xl gap-8 rounded-[2rem] bg-background/90 p-8 ring-1 ring-border sm:p-12 md:grid-cols-[11rem_minmax(0,1fr)] md:items-center lg:p-16 dark:bg-white/[0.03]"
      data-author-card
    >
      <Image
        src={authorImage}
        alt={author?.data.name ?? title}
        width={160}
        height={160}
        class="mx-auto size-36 rounded-full object-cover ring-4 ring-muted md:size-40"
      />
      <div class="text-center md:text-left">
        <h2 class="text-5xl font-semibold text-foreground sm:text-6xl">
          {author?.data.name ?? title}
        </h2>
        <p class="mt-6 text-lg leading-8 text-muted-foreground sm:text-xl">
          {author?.data.bio}
        </p>
        <nav
          class="mt-8 flex flex-wrap justify-center gap-3 md:justify-start"
          aria-label={t(lang, "pages.author.links")}
        >
          {
            author?.data.socials.map((social) => (
              <a
                class="inline-flex size-11 items-center justify-center rounded-full bg-muted text-muted-foreground transition hover:-translate-y-0.5 hover:bg-accent hover:text-foreground"
                href={social.url}
                aria-label={social.label}
                target={social.url.startsWith("http") ? "_blank" : undefined}
                rel={social.url.startsWith("http") ? "noreferrer" : undefined}
              >
                {social.label === "GitHub" ? (
                  <Icon name="github" class="size-5" dataIcon="inline-start" />
                ) : social.label === "Website" ? (
                  <Icon name="globe" class="size-5" dataIcon="inline-start" />
                ) : social.label === "RSS" ? (
                  <Icon name="rss" class="size-5" dataIcon="inline-start" />
                ) : (
                  <span class="text-xl leading-none" aria-hidden="true">
                    ×
                  </span>
                )}
              </a>
            ))
          }
        </nav>
      </div>
    </article>
    <section
      class="mx-auto mt-24 max-w-5xl rounded-[2rem] bg-muted/30 p-6 ring-1 ring-border sm:p-10 dark:bg-white/[0.03]"
      data-writing-activity
    >
      <div
        class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between"
      >
        <h2 class="text-2xl font-semibold text-foreground">
          {writingActivityLabel}
        </h2>
        <div class="flex flex-wrap gap-3 sm:grid">
          {
            (publicationYears.length > 0
              ? publicationYears.slice(0, 3)
              : [activeYear]
            ).map((year, index) => (
              <span
                class={`inline-flex h-10 items-center justify-center rounded-full px-6 text-sm font-semibold ${
                  index === 0
                    ? "bg-foreground text-background"
                    : "border border-border text-muted-foreground"
                }`}
              >
                {year}
              </span>
            ))
          }
        </div>
      </div>
      <div class="mt-7 overflow-x-auto pb-2">
        <div class="min-w-[52rem]">
          <div class="mb-3 grid grid-cols-12 gap-4 text-sm text-foreground/80">
            {activityMonths.map((month) => <span>{month}</span>)}
          </div>
          <div class="flex gap-1" aria-hidden="true">
            {
              activityWeeks.map((week) => (
                <div class="grid shrink-0 gap-1">
                  {week.map((day) => (
                    <span
                      class={`size-3 rounded-[0.2rem] ${activityLevelClass(day.count)}`}
                      data-day={day.key}
                      title={`${day.label}: ${day.count}`}
                    />
                  ))}
                </div>
              ))
            }
          </div>
        </div>
        <div
          class="mt-3 flex min-w-[52rem] flex-wrap items-center justify-between gap-4 text-sm text-muted-foreground"
        >
          <div class="flex items-center gap-2">
            <span>{t(lang, "pages.author.less")}</span>
            <span class="size-3 rounded-[0.2rem] bg-muted ring-1 ring-border"
            ></span>
            <span class="size-3 rounded-[0.2rem] bg-[#9be9a8] dark:bg-[#0e4429]"
            ></span>
            <span class="size-3 rounded-[0.2rem] bg-[#40c463] dark:bg-[#006d32]"
            ></span>
            <span class="size-3 rounded-[0.2rem] bg-[#30a14e] dark:bg-[#26a641]"
            ></span>
            <span class="size-3 rounded-[0.2rem] bg-[#216e39] dark:bg-[#39d353]"
            ></span>
            <span>{t(lang, "pages.author.more")}</span>
          </div>
          <p>
            {
              t(lang, "pages.author.contributionsInYear", {
                count: yearPostCount,
                year: activeYear,
              })
            }
          </p>
        </div>
        {
          recentPublishedPosts.length > 0 && (
            <div class="mt-8 grid gap-3" data-author-published-list>
              {recentPublishedPosts.map((post) => (
                <a
                  href={postUrl(post)}
                  class="grid gap-1 rounded-lg border border-border bg-background/70 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:bg-accent/70 dark:bg-white/[0.03]"
                >
                  <span class="text-xs font-medium text-muted-foreground">
                    {publishedText}: {dateFormatter.format(post.data.pubDate)}
                  </span>
                  <span class="font-semibold text-foreground">
                    {post.data.title}
                  </span>
                </a>
              ))}
            </div>
          )
        }
      </div>
    </section>
  </PageSection>
</Layout>
