---
import Layout from "@/layouts/main.astro"
import PostCardCover from "@/components/cards/PostCardCover.astro"
import PageHeader from "@/components/layout/PageHeader.astro"
import PostCardGrid from "@/components/lists/PostCardGrid.astro"
import PostArchiveList from "@/components/lists/PostArchiveList.astro"
import PostTextCardGrid from "@/components/lists/PostTextCardGrid.astro"
import Pagination from "@/components/navigation/Pagination.astro"
import { SITE_CONFIG } from "@/config/site"
import { LOCALES, type Locale } from "@/config/locales"
import { POSTS_PER_PAGE } from "@/config/pagination"
import { getPostsForLocale } from "@/utils/posts"
import { t } from "@/utils/translations"

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang }, props: { lang } }))
}

const { lang } = Astro.props as { lang: Locale }
const posts = await getPostsForLocale(lang)
const [lead, ...rest] = posts
const widePosts = rest.slice(0, 2)
const gridPosts = rest.slice(2, POSTS_PER_PAGE - 1)
const nextPage = posts.length > POSTS_PER_PAGE ? `/${lang}/2/` : undefined
const homepageLayout = SITE_CONFIG.homepage.layout
const archivePosts = posts.slice(0, POSTS_PER_PAGE)
---

<Layout
  lang={lang}
  path="/"
  title="Polyglow"
  description={lead?.data.description}
  image={lead?.data.heroImage}
>
  {
    homepageLayout === "archive" ? (
      <section
        class="mx-auto max-w-6xl px-4 py-10 sm:px-6"
        data-pagefind-ignore
        data-home-surface
      >
        <PageHeader
          title={t(lang, "pages.posts.title")}
          subtitle={t(lang, "pages.posts.totalPosts", {
            count: posts.length,
          })}
        />
        <PostArchiveList posts={archivePosts} lang={lang} />
        <Pagination next={nextPage} currentPage={1} />
      </section>
    ) : homepageLayout === "text" ? (
      <section
        class="mx-auto max-w-6xl px-4 py-10 sm:px-6"
        data-pagefind-ignore
        data-home-surface
      >
        <PageHeader
          title={t(lang, "pages.posts.title")}
          subtitle={t(lang, "pages.posts.totalPosts", {
            count: posts.length,
          })}
        />
        <PostTextCardGrid posts={archivePosts} />
        <Pagination next={nextPage} currentPage={1} />
      </section>
    ) : (
      <section
        class="mx-auto max-w-6xl px-4 py-10 sm:px-6"
        data-pagefind-ignore
        data-home-surface
      >
        <h1 class="sr-only">Polyglow</h1>
        {lead && <PostCardCover post={lead} priority variant="lead" />}
        <div class="mt-6 grid grid-cols-12 gap-6">
          {widePosts.map((post) => (
            <PostCardCover
              post={post}
              priority
              variant="wide"
              class="col-span-12 md:col-span-6"
            />
          ))}
        </div>
        {gridPosts.length > 0 && (
          <PostCardGrid posts={gridPosts} class="mt-6" />
        )}
        <Pagination next={nextPage} currentPage={1} />
      </section>
    )
  }
</Layout>
